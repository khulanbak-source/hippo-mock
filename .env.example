# Copy to .env.local for local dev, and add the same keys in Vercel → Project → Settings → Environment Variables.

# Notion internal integration secret (starts with "ntn_" or "secret_").
# Create one at https://www.notion.so/my-integrations and SHARE the "Hippo" page with it.
NOTION_TOKEN=

# Optional: the Users database id. Defaults to the known Hippo Users DB if left blank.
NOTION_DB_ID=37b5bc947e198011a3c5e3553b795f52
